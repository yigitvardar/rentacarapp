# ==============================================
# VERİTABANI
# ==============================================
# PostgreSQL bağlantı adresi (Supabase, Neon, yerel vb.)
DATABASE_URL="postgresql://user:password@localhost:5432/rental_db"

# ==============================================
# NEXTAUTH
# ==============================================
# Üretim ortamı URL'i (örn: https://domain.com)
NEXTAUTH_URL="http://localhost:3000"
# Rastgele güçlü bir secret: `openssl rand -base64 32`
AUTH_SECRET="your-super-secret-key-here"

# ==============================================
# İYZİCO ÖDEME SİSTEMİ
# ==============================================
IYZICO_API_KEY="your-iyzico-api-key"
IYZICO_SECRET_KEY="your-iyzico-secret-key"
# Test için: https://sandbox-api.iyzipay.com
# Canlı için: https://api.iyzipay.com
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ==============================================
# SİGORTA API (Entegrasyon için)
# ==============================================
INSURANCE_API_URL="https://api.insurance-company.com"
INSURANCE_API_KEY="your-insurance-api-key"

# ==============================================
# UYGULAMA
# ==============================================
NEXT_PUBLIC_APP_NAME="Araç Kiralama"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
