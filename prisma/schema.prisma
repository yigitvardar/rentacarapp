// Prisma ORM şeması
// Veritabanı: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// KULLANICI YÖNETİMİ
// ============================================================

enum Role {
  USER
  ADMIN
}

enum PolicyStatus {
  ACTIVE      // Aktif poliçe
  EXPIRED     // Süresi dolmuş
  SUSPENDED   // Askıya alınmış
  NONE        // Poliçe yok
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt ile hashlenmiş
  phone         String?
  role          Role      @default(USER)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // İlişkiler
  sessions        Session[]
  accounts        Account[]
  tcVerifications TcVerification[]
  rentals         Rental[]
  issueReports    IssueReport[]

  @@map("users")
}

// NextAuth için gerekli modeller
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// TC KİMLİK & SİGORTA POLİÇESİ
// ============================================================

model TcVerification {
  id           String       @id @default(cuid())
  userId       String
  tcNumber     String       // Maskelenmiş saklanabilir (ör: ***5678)
  policyNumber String?      // Sigorta poliçe numarası
  policyStatus PolicyStatus @default(NONE)
  policyScope  Json?        // Poliçe kapsamı (JSON)
  verifiedAt   DateTime     @default(now())
  expiresAt    DateTime?    // Poliçe bitiş tarihi

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tc_verifications")
}

// ============================================================
// ARAÇ YÖNETİMİ
// ============================================================

enum VehicleStatus {
  AVAILABLE   // Müsait
  RENTED      // Kirada
  MAINTENANCE // Bakımda
  INACTIVE    // Pasif
}

enum FuelType {
  GASOLINE  // Benzin
  DIESEL    // Dizel
  ELECTRIC  // Elektrik
  HYBRID    // Hibrit
  LPG       // LPG
}

enum TransmissionType {
  MANUAL    // Manuel
  AUTOMATIC // Otomatik
}

model VehicleCategory {
  id          String    @id @default(cuid())
  name        String    @unique // Ekonomik, Orta Sınıf, SUV, Lüks, vb.
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())

  vehicles Vehicle[]
  packages RentalPackage[]

  @@map("vehicle_categories")
}

model Vehicle {
  id             String           @id @default(cuid())
  categoryId     String
  brand          String           // Marka (Toyota, Ford, vb.)
  model          String           // Model (Corolla, Focus, vb.)
  year           Int              // Üretim yılı
  plate          String           @unique // Plaka
  fuelType       FuelType
  transmission   TransmissionType
  seats          Int              @default(5)
  doors          Int              @default(4)
  imageUrl       String?
  dailyRate      Decimal          @db.Decimal(10, 2) // Günlük temel fiyat
  status         VehicleStatus    @default(AVAILABLE)
  features       Json?            // Ek özellikler (klima, navigasyon, vb.)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  category VehicleCategory @relation(fields: [categoryId], references: [id])
  rentals  Rental[]

  @@map("vehicles")
}

// ============================================================
// KİRALAMA PAKETLERİ
// ============================================================

model RentalPackage {
  id                String   @id @default(cuid())
  categoryId        String?  // Hangi araç kategorisi için
  name              String   // Paket adı
  description       String?
  durationDays      Int      // Kiralama süresi (gün)
  basePrice         Decimal  @db.Decimal(10, 2) // Temel fiyat
  discountRate      Decimal  @db.Decimal(5, 2)  @default(0) // İndirim oranı (%)
  finalPrice        Decimal  @db.Decimal(10, 2) // Son fiyat
  includedKm        Int?     // Dahil KM
  extraKmRate       Decimal? @db.Decimal(10, 2) // Ekstra KM ücreti
  insuranceCoverage Json?    // Hangi sigorta kapsamları bu pakete uygun
  policyTypes       String[] // Uygun poliçe tipleri
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category VehicleCategory? @relation(fields: [categoryId], references: [id])
  rentals  Rental[]

  @@map("rental_packages")
}

// ============================================================
// KİRALAMA İŞLEMLERİ
// ============================================================

enum RentalStatus {
  PENDING    // Beklemede (ödeme bekleniyor)
  CONFIRMED  // Onaylandı
  ACTIVE     // Aktif kiralama
  COMPLETED  // Tamamlandı
  CANCELLED  // İptal edildi
}

model Rental {
  id            String       @id @default(cuid())
  userId        String
  vehicleId     String
  packageId     String?
  tcNumber      String       // Kiralama anındaki TC (şifreli)
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  totalPrice    Decimal      @db.Decimal(10, 2)
  status        RentalStatus @default(PENDING)
  notes         String?
  discountCode  String?      // Kullanılan indirim kodu
  discountAmount Decimal?    @db.Decimal(10, 2) // İndirim tutarı
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  vehicle      Vehicle        @relation(fields: [vehicleId], references: [id])
  package      RentalPackage? @relation(fields: [packageId], references: [id])
  payment      Payment?
  issueReports IssueReport[]

  @@map("rentals")
}

// ============================================================
// SORUN BİLDİRİMLERİ
// ============================================================

model IssueReport {
  id        String   @id @default(cuid())
  rentalId  String
  userId    String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  rental Rental @relation(fields: [rentalId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("issue_reports")
}

// ============================================================
// RATE LIMITING
// ============================================================

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique  // "tc-verify:userId" veya "register:ip"
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rate_limits")
}

// ============================================================
// ÖDEME
// ============================================================

enum PaymentStatus {
  PENDING   // Beklemede
  SUCCESS   // Başarılı
  FAILED    // Başarısız
  REFUNDED  // İade edildi
}

model Payment {
  id              String        @id @default(cuid())
  rentalId        String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  // İyzico response alanları
  iyzicoPaymentId String?
  iyzicoToken     String?
  iyzicoResponse  Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rental Rental @relation(fields: [rentalId], references: [id])

  @@map("payments")
}

// ============================================================
// İNDİRİM KODU
// ============================================================

model DiscountCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Decimal   @db.Decimal(5, 2)  // % indirim
  maxUses         Int?      // null = sınırsız
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("discount_codes")
}
